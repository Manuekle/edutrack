// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Jornada {
  DIURNO
  NOCTURNO
}

enum Role {
  ADMIN
  DOCENTE
  ESTUDIANTE
  COORDINADOR
}

enum UnenrollRequestStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum AttendanceStatus {
  PRESENTE
  AUSENTE
  TARDANZA
  JUSTIFICADO
}

enum ClassStatus {
  PROGRAMADA
  REALIZADA
  CANCELADA
}

enum ReportStatus {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  FALLIDO
}

enum ReportFormat {
  PDF
  CSV
}

enum DayOfWeek {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum EventType {
  EXAMEN
  TRABAJO
  LIMITE
  ANUNCIO
  INFO
}

enum RoomType {
  SALA_COMPUTO
  SALON
  AUDITORIO
}

enum BookingStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum EnrollmentStatus {
  ACTIVA
  CANCELADA
  APLAZADA
  FINALIZADA
}

enum Periodicidad {
  SEMANAL
  QUINCENAL
}

enum TipoCompetencia {
  RAP
  RAC
  COMPETENCIA
}

enum EstadoClase {
  PROGRAMADA
  REALIZADA
  CANCELADA
}

// ============================================================
// USUARIOS
// ============================================================

model User {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  name                String?
  document            String?   @unique
  emailVerified       DateTime?
  correoPersonal      String?   @unique
  correoInstitucional String?   @unique
  telefono            String?
  codigoEstudiantil   String?
  codigoDocente       String?
  signatureUrl        String?
  password            String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  role                Role      @default(ESTUDIANTE)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relaciones como Docente (asignaturas antiguas)
  subjectsAsTeacherIds String[]     @db.ObjectId
  subjectsAsTeacher    Subject[]    @relation("TeacherSubjects", fields: [subjectsAsTeacherIds], references: [id])
  createdEvents        SubjectEvent[]
  generatedReports     Report[]

  // Relaciones como Estudiante (antiguo)
  enrolledSubjectIds String[]     @db.ObjectId
  attendances        Attendance[]

  // Solicitudes desmatriculación
  requestedUnenrolls UnenrollRequest[] @relation("RequestedUnenrolls")
  unenrollRequests   UnenrollRequest[] @relation("StudentUnenrolls")
  reviewedUnenrolls  UnenrollRequest[] @relation("ReviewedUnenrolls")

  // Salas
  roomBookings RoomBooking[] @relation("TeacherBookings")

  // Flujo administrativo antiguo
  groupAssignments GroupAssignment[] @relation("StudentGroupAssignments")
  enrollments      Enrollment[]      @relation("StudentEnrollments")

  // Nuevos: Grupos académicos
  gruposComoDocenteIds    String[]  @db.ObjectId
  gruposComoDocente       Grupo[]   @relation("DocenteGrupos", fields: [gruposComoDocenteIds], references: [id])
  gruposComoEstudianteIds String[]  @db.ObjectId
  gruposComoEstudiante    Grupo[]   @relation("EstudiantesGrupo", fields: [gruposComoEstudianteIds], references: [id])
}

// ============================================================
// ASIGNATURAS
// ============================================================

model Subject {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  code             String
  group            String?
  jornada          Jornada?
  program          String?
  semester         Int?
  credits          Int?
  directHours      Int?
  description      String?
  periodoAcademico String?
  teachers         User[]            @relation("TeacherSubjects", fields: [teacherIds], references: [id])
  teacherIds       String[]          @db.ObjectId
  studentIds       String[]          @db.ObjectId
  classroom        String?
  classes          Class[]
  events           SubjectEvent[]
  reports          Report[]
  unenrollRequests UnenrollRequest[]
  contents         SubjectContent[]
  enrollments      Enrollment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Nuevas relaciones
  microcurriculo   Microcurriculo?
  grupos           Grupo[]
  horarios         Horario[]

  @@index([teacherIds])
  @@unique([code, group])
}

// ============================================================
// MÓDULO 1: MICROCURRÍCULO
// ============================================================

model Microcurriculo {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  subject         Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId       String        @unique @db.ObjectId

  // Datos generales
  objetivoGeneral           String?
  descripcionAsignatura     String?
  horasTrabajIndependiente  Int?
  habilitable               Boolean  @default(false)
  conocimientosPrevios      String[] // materias previas requeridas
  estrategiasAprendizaje    String[] // metodologías seleccionadas

  // Contenido académico
  temas           Tema[]
  competencias    Competencia[]  // RAPs y RACs
  bibliografias   Bibliografia[]
  cibergrafia     Cibergrafia[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Tema {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  microcurriculo   Microcurriculo @relation(fields: [microcurriculoId], references: [id], onDelete: Cascade)
  microcurriculoId String         @db.ObjectId
  titulo           String         // "1. PRINCIPIOS DE SEGURIDAD DE LA INFORMACIÓN"
  orden            Int            @default(0)
  subtemas         Subtema[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([microcurriculoId])
}

model Subtema {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  tema     Tema     @relation(fields: [temaId], references: [id], onDelete: Cascade)
  temaId   String   @db.ObjectId
  titulo   String   // "1.1 Definición y conceptos de seguridad..."
  orden    Int      @default(0)

  @@index([temaId])
}

model Competencia {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  microcurriculo   Microcurriculo  @relation(fields: [microcurriculoId], references: [id], onDelete: Cascade)
  microcurriculoId String          @db.ObjectId
  descripcion      String
  tipo             TipoCompetencia @default(RAP)
  codigo           String?         // "RAP 1", "RAP 2", "RAC 1"
  aplica           Boolean         @default(true) // checkbox si este RAP aplica
  orden            Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([microcurriculoId])
}

model Bibliografia {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  microcurriculo   Microcurriculo @relation(fields: [microcurriculoId], references: [id], onDelete: Cascade)
  microcurriculoId String         @db.ObjectId
  autores          String
  titulo           String
  editorial        String?
  anio             Int?
  orden            Int            @default(0)

  @@index([microcurriculoId])
}

model Cibergrafia {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  microcurriculo   Microcurriculo @relation(fields: [microcurriculoId], references: [id], onDelete: Cascade)
  microcurriculoId String         @db.ObjectId
  autores          String?
  titulo           String
  url              String?
  anio             Int?
  orden            Int            @default(0)

  @@index([microcurriculoId])
}

// ============================================================
// MÓDULO 2: PLANEADOR
// ============================================================

model Horario {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  diaSemana    DayOfWeek
  horaInicio   String       // "HH:MM" formato 24h
  horaFin      String       // "HH:MM" formato 24h
  periodicidad Periodicidad @default(SEMANAL)
  subjectId    String?      @db.ObjectId
  subject      Subject?     @relation(fields: [subjectId], references: [id])
  salaId       String?      @db.ObjectId
  sala         Room?        @relation(fields: [salaId], references: [id])
  grupos       Grupo[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([diaSemana])
  @@index([subjectId])
  @@index([salaId])
}

model Grupo {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  codigo           String
  subject          Subject     @relation(fields: [subjectId], references: [id])
  subjectId        String      @db.ObjectId
  periodoAcademico String

  // Docente asignado
  docenteIds  String[] @db.ObjectId
  docentes    User[]   @relation("DocenteGrupos", fields: [docenteIds], references: [id])

  // Horario asignado
  horario   Horario? @relation(fields: [horarioId], references: [id])
  horarioId String?  @db.ObjectId

  // Sala asignada
  sala   Room?   @relation(fields: [salaId], references: [id])
  salaId String? @db.ObjectId

  // Estudiantes
  estudianteIds String[] @db.ObjectId
  estudiantes   User[]   @relation("EstudiantesGrupo", fields: [estudianteIds], references: [id])

  // Planeación y clases
  planeacion Planeacion?
  clases     Class[]     @relation("GrupoClases")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([codigo, subjectId, periodoAcademico])
  @@index([subjectId])
  @@index([docenteIds])
}

model Planeacion {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  grupo       Grupo             @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  grupoId     String            @unique @db.ObjectId
  fechaInicio DateTime
  fechaFin    DateTime?
  semanas     SemanaAcademica[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model SemanaAcademica {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  planeacion   Planeacion @relation(fields: [planeacionId], references: [id], onDelete: Cascade)
  planeacionId String     @db.ObjectId
  numero       Int        // 1-16
  fechaInicio  DateTime
  fechaFin     DateTime
  clases       Class[]    @relation("SemanaClases")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([planeacionId])
}

// ============================================================
// MÓDULO 3: CLASES Y BITÁCORA
// ============================================================

model Class {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  date               DateTime
  startTime          DateTime?
  endTime            DateTime?
  topic              String?
  description        String?
  status             ClassStatus      @default(PROGRAMADA)
  cancellationReason String?
  subject            Subject          @relation(fields: [subjectId], references: [id])
  subjectId          String           @db.ObjectId
  classroom          String?
  jornada            Jornada?
  attendances        Attendance[]
  qrToken            String?
  qrTokenExpiresAt   DateTime?
  notificationSentAt DateTime?

  // Métricas de asistencia (cached)
  totalStudents  Int @default(0)
  presentCount   Int @default(0)
  absentCount    Int @default(0)
  lateCount      Int @default(0)
  justifiedCount Int @default(0)

  // Nuevas relaciones: Planeador y Bitácora
  grupo    Grupo?           @relation("GrupoClases", fields: [grupoId], references: [id])
  grupoId  String?          @db.ObjectId
  semana   SemanaAcademica? @relation("SemanaClases", fields: [semanaId], references: [id])
  semanaId String?          @db.ObjectId
  bitacora Bitacora?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId, status, date])
  @@index([subjectId, date])
  @@index([status, date])
  @@index([qrToken])
  @@index([classroom, date])
  @@index([grupoId])
  @@index([semanaId])
}

model Bitacora {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId        String   @unique @db.ObjectId
  temaPlaneado   String?
  temaEjecutado  String?
  actividades    String?
  observaciones  String?
  evidencias     String[] // URLs de archivos subidos
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// ASISTENCIA
// ============================================================

model Attendance {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  status        AttendanceStatus
  justification String?
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String           @db.ObjectId
  class         Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId       String           @db.ObjectId
  recordedAt    DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([studentId, classId])
  @@index([studentId, status])
  @@index([classId, status])
}

// ============================================================
// REPORTES Y EVENTOS
// ============================================================

model Report {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  subject       Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId     String       @db.ObjectId
  requestedBy   User         @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  requestedById String       @db.ObjectId
  status        ReportStatus @default(PENDIENTE)
  format        ReportFormat @default(PDF)
  period        Int          @default(1)
  year          Int          @default(2025)
  fileUrl       String?
  fileName      String?
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([subjectId])
  @@index([requestedById])
}

model SubjectEvent {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  date        DateTime
  type        EventType @default(INFO)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String    @db.ObjectId
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String    @db.ObjectId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subjectId, date])
}

model SubjectContent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String   @db.ObjectId
  type        String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subjectId])
}

// ============================================================
// SALAS
// ============================================================

model Room {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        RoomType      @default(SALON)
  capacity    Int?
  description String?
  isActive    Boolean       @default(true)
  bookings    RoomBooking[]
  grupos      Grupo[]
  horarios    Horario[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
}

model RoomBooking {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  room          Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId        String        @db.ObjectId
  teacher       User          @relation("TeacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId     String        @db.ObjectId
  startTime     DateTime
  endTime       DateTime
  reason        String
  status        BookingStatus @default(PENDIENTE)
  signatureUrl  String?
  reviewComment String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([roomId, startTime, endTime])
  @@index([teacherId])
  @@index([status])
}

// ============================================================
// MATRÍCULAS Y GRUPOS (legacy + nuevo flujo)
// ============================================================

model UnenrollRequest {
  id            String                @id @default(auto()) @map("_id") @db.ObjectId
  student       User?                 @relation("StudentUnenrolls", fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String                @db.ObjectId
  subject       Subject?              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId     String                @db.ObjectId
  reason        String
  status        UnenrollRequestStatus @default(PENDIENTE)
  requestedBy   User?                 @relation("RequestedUnenrolls", fields: [requestedById], references: [id], onDelete: Cascade)
  requestedById String                @db.ObjectId
  reviewedBy    User?                 @relation("ReviewedUnenrolls", fields: [reviewedById], references: [id])
  reviewedById  String?               @db.ObjectId
  reviewComment String?
  reviewedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([studentId, subjectId, status])
}

model GroupAssignment {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  student          User     @relation("StudentGroupAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  studentId        String   @db.ObjectId
  grupoNombre      String
  periodoAcademico String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, grupoNombre, periodoAcademico])
  @@index([grupoNombre, periodoAcademico])
}

model Enrollment {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  student          User             @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  studentId        String           @db.ObjectId
  subject          Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId        String           @db.ObjectId
  periodoAcademico String
  status           EnrollmentStatus @default(ACTIVA)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([studentId, subjectId, periodoAcademico])
  @@index([subjectId, status])
  @@index([studentId, status])
}
