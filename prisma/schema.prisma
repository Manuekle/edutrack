// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS (Hybrid: Core enums in Spanish, others in English)
// ============================================================

enum Shift {
  DAY
  NIGHT
}

enum Role {
  ADMIN
  DOCENTE
  ESTUDIANTE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum ClassStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  SIGNED
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReportFormat {
  PDF
  CSV
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RoomType {
  LABORATORIO
  SALA_CLASE
  AUDITORIO
}

// ============================================================
// MODELS (Fields in English)
// ============================================================

model User {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  name                String?
  document            String?   @unique
  emailVerified       DateTime?
  personalEmail       String?   @unique
  institutionalEmail  String?   @unique
  phone               String?
  studentCode         String?
  teacherCode         String?
  signatureUrl        String?
  password            String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  role                Role      @default(ESTUDIANTE)
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Teacher relationships
  subjectsAsTeacherIds String[]     @db.ObjectId
  subjectsAsTeacher    Subject[]    @relation("TeacherSubjects", fields: [subjectsAsTeacherIds], references: [id])
  generatedReports     Report[]

  // Student relationships
  attendances        Attendance[]

  // Academic Groups
  teacherGroupsIds    String[]  @db.ObjectId
  teacherGroups       Group[]   @relation("TeacherGroups", fields: [teacherGroupsIds], references: [id])
  // Student groups
  studentGroupsIds    String[]  @db.ObjectId
  studentGroups       Group[]   @relation("StudentGroups", fields: [studentGroupsIds], references: [id])

  // Unenrollment requests
  unenrollRequests          UnenrollRequest[] @relation("StudentUnenrollments")
  unenrollRequestsRequested UnenrollRequest[] @relation("TeacherUnenrollRequests")
}

model Subject {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  code             String
  group            String?
  shift            Shift?
  program          String?
  semester         Int?
  credits          Int?
  directHours      Int?
  description      String?
  academicPeriod   String?
  teachers         User[]            @relation("TeacherSubjects", fields: [teacherIds], references: [id])
  teacherIds       String[]          @db.ObjectId
  studentIds       String[]          @db.ObjectId
  classroom        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  groups           Group[]
  schedules        Schedule[]
  reports          Report[]
  classes          Class[]

  @@index([teacherIds])
  @@unique([code, group])

  // Unenrollment requests
  unenrollRequests UnenrollRequest[] @relation("SubjectUnenrollments")
}

model Schedule {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek    DayOfWeek
  startTime    String
  endTime      String
  subjectId    String?     @db.ObjectId
  subject      Subject?    @relation(fields: [subjectId], references: [id])
  roomId       String?     @db.ObjectId
  room         Room?       @relation(fields: [roomId], references: [id])
  groups       Group[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([dayOfWeek])
  @@index([subjectId])
  @@index([roomId])
}

model Group {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  code             String
  subject          Subject  @relation(fields: [subjectId], references: [id])
  subjectId        String   @db.ObjectId
  academicPeriod   String

  // Assigned Teacher
  teacherIds  String[] @db.ObjectId
  teachers    User[]   @relation("TeacherGroups", fields: [teacherIds], references: [id])

  // Assigned Schedule
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  scheduleId  String?   @db.ObjectId

  // Assigned Room
  room        Room?   @relation(fields: [roomId], references: [id])
  roomId      String? @db.ObjectId

  // Students
  studentIds  String[] @db.ObjectId
  students    User[]   @relation("StudentGroups", fields: [studentIds], references: [id])

  // Planning and classes
  planning    Planning?
  classes     Class[]     @relation("GroupClasses")
  shift       Shift?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@unique([code, subjectId, academicPeriod])
  @@index([subjectId])
  @@index([teacherIds])
}

model Planning {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String            @unique @db.ObjectId
  startDate   DateTime
  endDate     DateTime?
  weeks       AcademicWeek[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AcademicWeek {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  planning     Planning   @relation(fields: [planningId], references: [id], onDelete: Cascade)
  planningId   String     @db.ObjectId
  number       Int        // 1-16
  startDate    DateTime
  endDate      DateTime
  classes      Class[]    @relation("WeekClasses")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([planningId])
}

model Class {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  date               DateTime
  startTime          DateTime?
  endTime            DateTime?
  topic              String?
  description        String?
  status             ClassStatus      @default(SCHEDULED)
  cancellationReason String?
  subject            Subject          @relation(fields: [subjectId], references: [id])
  subjectId          String           @db.ObjectId
  classroom          String?
  shift              Shift?
  attendances        Attendance[]
  qrToken            String?
  qrTokenExpiresAt   DateTime?
  notificationSentAt DateTime?

  // Attendance metrics (cached)
  totalStudents  Int @default(0)
  presentCount   Int @default(0)
  absentCount    Int @default(0)
  lateCount      Int @default(0)
  justifiedCount Int @default(0)

  // Relations: Planner and Logbook
  group    Group?        @relation("GroupClasses", fields: [groupId], references: [id])
  groupId  String?       @db.ObjectId
  week     AcademicWeek? @relation("WeekClasses", fields: [weekId], references: [id])
  weekId   String?       @db.ObjectId
  logbook  Logbook?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId, status, date])
  @@index([subjectId, date])
  @@index([status, date])
  @@index([qrToken])
  @@index([classroom, date])
  @@index([groupId])
  @@index([weekId])
}

model Logbook {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId        String   @unique @db.ObjectId
  plannedTopic   String?
  executedTopic  String?
  activities     String?
  observations   String?
  evidence       String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Attendance {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  status        AttendanceStatus
  justification String?
  student       User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     String           @db.ObjectId
  class         Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId       String           @db.ObjectId
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([studentId, classId])
  @@index([studentId, status])
  @@index([classId, status])
}

model Report {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  subject       Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId     String       @db.ObjectId
  requestedBy   User         @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  requestedById String       @db.ObjectId
  status        ReportStatus @default(PENDING)
  format        ReportFormat @default(PDF)
  period        Int          @default(1)
  year          Int          @default(2025)
  fileUrl       String?
  fileName      String?
  error         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([subjectId])
  @@index([requestedById])
}

model Room {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        RoomType      @default(SALA_CLASE)
  capacity    Int?
  description String?
  isActive    Boolean       @default(true)
  groups      Group[]
  schedules   Schedule[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
}

model AcademicPeriod {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique // Ej: "2026-1", "20261"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UnenrollRequest {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  student        User         @relation("StudentUnenrollments", fields: [studentId], references: [id])
  studentId      String       @db.ObjectId
  subject        Subject      @relation("SubjectUnenrollments", fields: [subjectId], references: [id])
  subjectId      String       @db.ObjectId
  reason         String
  status         UnenrollStatus @default(PENDING)
  requestedBy    User         @relation("TeacherUnenrollRequests", fields: [requestedById], references: [id])
  requestedById  String       @db.ObjectId
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([studentId])
  @@index([subjectId])
  @@index([requestedById])
}

enum UnenrollStatus {
  PENDING
  APPROVED
  REJECTED
}
